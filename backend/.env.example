BIND_ADDR=127.0.0.1:8080
DATABASE_URL=postgres://check_in:replace-me@127.0.0.1:5432/check_in
REDIS_URL=redis://127.0.0.1:6379/

# Use independently generated secrets of at least 32 bytes.
JWT_SECRET=replace-with-at-least-32-random-bytes
DEVICE_ENROLLMENT_TOKEN=replace-with-an-independent-32-byte-token
JWT_TTL_SECONDS=3600

CORS_ALLOWED_ORIGIN=http://localhost:3000,http://127.0.0.1:3000
TRUST_PROXY_HEADERS=false
REJECT_EMULATORS=true
REDIS_FAIL_CLOSED=true
RATE_LIMIT_PER_MINUTE=60

ALLOW_DEV_AUTH=false
DEV_AUTH_SECRET=replace-with-an-independent-32-byte-secret
DEV_USER_ID=1
DEV_DISPLAY_NAME=Demo User
DEV_TOKEN_TTL_SECONDS=86400

DATABASE_MAX_CONNECTIONS=5
REQUEST_BODY_LIMIT_BYTES=65536
REQUEST_TIMEOUT_SECONDS=15
RUST_LOG=check_in_backend=info,tower_http=info
